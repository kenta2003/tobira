# ============================================================
# Required: Supabase (DB / Auth / Storage)
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ============================================================
# Optional: Site
# ============================================================
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ============================================================
# Optional: Stripe (premium subscription)
# ============================================================
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_ID=price_xxx

# ============================================================
# Optional: Instagram Graph API (semi-automated posting)
# ============================================================
INSTAGRAM_ACCESS_TOKEN=your-long-lived-token
INSTAGRAM_BUSINESS_ACCOUNT_ID=your-business-account-id
INSTAGRAM_ADMIN_SECRET=any-random-secret-for-admin-ui

# ============================================================
# Optional: Photo collection scripts
# ============================================================
PEXELS_API_KEY=your-pexels-api-key
UNSPLASH_ACCESS_KEY=your-unsplash-access-key
FLICKR_API_KEY=your-flickr-api-key

# ============================================================
# Optional: Article generation
# ============================================================
ANTHROPIC_API_KEY=sk-ant-xxx

# ============================================================
# Optional: Contact form
# ============================================================
RESEND_API_KEY=re_xxx

# ============================================================
# Optional: Rate limiting
# ============================================================
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# ============================================================
# Optional: Analytics / Ads
# ============================================================
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
NEXT_PUBLIC_ADSENSE_CLIENT=ca-pub-xxxxxxxxxx
NEXT_PUBLIC_ADSENSE_SLOT=xxxxxxxxxx

# ============================================================
# Optional: Admin allowlist (comma-separated user IDs)
# ============================================================
ADMIN_USER_IDS=

# ============================================================
# Optional: Direct DB connection (migration scripts)
# ============================================================
SUPABASE_DB_URL=postgresql://postgres.your-project-ref:password@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres
